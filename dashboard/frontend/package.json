{
  "name": "@agentpanels/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false && tsc -p tsconfig.node.json --noEmit --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentpanels/shared": "file:../shared",
    "@vitejs/plugin-react": "^4.4.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.3.3"
  },
  "devDependencies": {
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "vitest": "^3.2.4",
    "typescript": "^5.8.3"
  }
}
